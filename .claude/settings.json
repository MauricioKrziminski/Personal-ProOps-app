{
  "enabledPlugins": {
    "expo@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(npm run:*)",
      "Bash(npm install)",
      "Bash(npx expo start:*)",
      "Bash(npx expo lint:*)",
      "Bash(npx expo prebuild:*)",
      "Bash(npx expo install:*)",
      "Bash(npx tsc:*)",
      "Bash(npx supabase db push:*)",
      "Bash(npx supabase db diff:*)",
      "Bash(npx supabase functions serve:*)",
      "Bash(npx supabase functions deploy:*)",
      "Bash(npx supabase gen types:*)",
      "Bash(npx supabase migration:*)",
      "Bash(npx supabase status:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)"
    ]
  }
