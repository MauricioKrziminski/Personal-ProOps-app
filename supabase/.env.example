# Segredos das Edge Functions — configure com: supabase secrets set --env-file supabase/.env
# NUNCA commitar o .env real. NUNCA colocar estas chaves no app mobile.

# Google Gemini (parsing/categorização das mensagens)
GEMINI_API_KEY=

# Groq (Whisper — transcrição de áudios do WhatsApp)
GROQ_API_KEY=

# Meta WhatsApp Cloud API
WHATSAPP_TOKEN=                # token permanente do system user
WHATSAPP_APP_SECRET=           # p/ validar X-Hub-Signature-256 (HMAC) do webhook
WHATSAPP_VERIFY_TOKEN=         # string aleatória sua, usada no GET de verificação do webhook
WHATSAPP_PHONE_NUMBER_ID=      # ID do número no WhatsApp Business

# Observação: SUPABASE_URL e SUPABASE_SERVICE_ROLE_KEY são injetadas
# automaticamente pelo runtime das Edge Functions — não precisam ser definidas.
